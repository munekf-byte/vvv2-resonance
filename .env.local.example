# ===== VALVRAVE-RESONANCE 環境変数 =====
# このファイルを .env.local にコピーして実際の値を入力してください

NEXT_PUBLIC_SUPABASE_URL=https://whbvjeujnspzaxqboyzn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndoYnZqZXVqbnNwemF4cWJveXpuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NTU5MTksImV4cCI6MjA5MDQzMTkxOX0.lvuOaA0nOBV84qLUjnqQ1d6NCFC9y1-52h22vmRwUqg

# ===== Discord Bot 連携 =====
DISCORD_BOT_API_URL=https://hivemind-bot-li18.onrender.com
DISCORD_BOT_API_SECRET=（Bot側の .env にある BOT_API_SECRET と同じ値を入れる）

# ===== Discord OAuth（ユーザー連携） =====
# Discord Developer Portal → OAuth2 から取得
# Redirects に追加するURL: https://<your-domain>/api/discord-oauth/callback
DISCORD_CLIENT_ID=（Discord Application の Client ID）
DISCORD_CLIENT_SECRET=（Discord Application の Client Secret）

# ===== Stripe 決済（一時停止中は false にする） =====
# クレジットカード決済を有効化したいときだけ true
NEXT_PUBLIC_STRIPE_ENABLED=false

# ===== メール送信（Resend） =====
# Resend ダッシュボードで API キーを発行 → ここに貼り付け
# 未設定でもアプリは動作する（メール送信のみ skip される）
RESEND_API_KEY=（Resend の API キー / 例: re_xxxxxxxxxxxxxxxx）
MAIL_FROM=TGR Resonance <noreply@your-verified-domain>

# ===== 管理者通知（PayPay 送金報告の通知先） =====
# 未設定でも動作するが、設定するとユーザー送金時に管理者へメール通知される
ADMIN_NOTIFICATION_EMAIL=（管理者のメールアドレス）

# ===== アプリの公開URL（メール本文のリンクに使用） =====
NEXT_PUBLIC_APP_URL=https://your-app-domain.example.com
